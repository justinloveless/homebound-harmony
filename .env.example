# Copy to `.env` and fill in real values:
#   cp .env.example .env
# Then `docker compose up --build` will pick these up automatically.

# --- Postgres -----------------------------------------------------------
# These map straight onto the postgres service. Defaults are fine for local.
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
# Optional: when merging docker-compose.local.yaml, Postgres is bound on the host at this port (see compose file).
# POSTGRES_PUBLISH_PORT=55432

# --- App ----------------------------------------------------------------
# Dotted version string; must stay in lockstep with web `VITE_APP_CLIENT_VERSION`
# / `APP_CLIENT_VERSION` and iOS `ClientVersion.current`. Sent as `X-Min-Client-Version`
# on GET `/api/auth/me` and echoed on legacy 410 responses.
MIN_CLIENT_VERSION=2026.5.6

# `development` keeps the session cookie name as `session` so plain-HTTP
# localhost works. Set to `production` once the app is behind TLS.
NODE_ENV=development

# Set to false to skip the apple.test@gmail.com seed on API startup (Docker CMD runs migrations + seed by default).
# RUN_SEED_ON_BOOT=false

# Host port the API + bundled SPA binds to (container always uses 3000).
APP_PORT=3000
# Host port the dev Vite SPA binds to (container always uses 8080).
# 8080 is often already taken on Windows hosts (Hyper-V reservations),
# so 5173 (Vite's classic default) is a safer pick.
WEB_PORT=5173

# 64 hex characters (32 bytes). Wraps each user's TOTP secret at rest.
# Generate with: openssl rand -hex 32
TOTP_KEK=replace-me-with-64-hex-chars-replace-me-with-64-hex-chars-1234567

# HMAC pepper for hashing client IPs in the audit log. Treat as a secret;
# rotate periodically (rotation makes prior IPs uncorrelatable).
# Generate with: openssl rand -base64 32
IP_HASH_PEPPER=replace-me-with-a-long-random-string

# Optional: platform admin UI (`/admin/*`, `/api/admin/*`). Comma, newline, or semicolon separated.
# Must match the logged-in user's email (see GET /api/auth/me). Include seeded review accounts here as needed.
# Example:
#   ADMIN_EMAILS=you@example.com,apple.test@gmail.com
# Singular fallback if you prefer one variable:
#   ADMIN_EMAIL=you@example.com
ADMIN_EMAILS=
ADMIN_EMAIL=

# Optional: emails that bypass MFA (TOTP) at login. Comma, newline, or semicolon
# separated. Intended for App Store review accounts and tightly-scoped automated
# environments. Anyone listed here can sign in with just a password — treat this
# variable as a sensitive operational toggle and leave empty in production.
#   MFA_DISABLED_EMAILS=review@example.com,e2e-bot@example.com
MFA_DISABLED_EMAILS=
