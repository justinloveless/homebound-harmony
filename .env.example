# Copy to `.env` and fill in real values:
#   cp .env.example .env
# Then `docker compose up --build` will pick these up automatically.

# --- Postgres -----------------------------------------------------------
# These map straight onto the postgres service. Defaults are fine for local.
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# --- App ----------------------------------------------------------------
# Dotted version string; must stay in lockstep with web `VITE_APP_CLIENT_VERSION`
# / `APP_CLIENT_VERSION` and iOS `ClientVersion.current`. Sent as `X-Min-Client-Version`
# on GET `/api/auth/me` and echoed on legacy 410 responses.
MIN_CLIENT_VERSION=2026.5.6

# `development` keeps the session cookie name as `session` so plain-HTTP
# localhost works. Set to `production` once the app is behind TLS.
NODE_ENV=development

# Host port the API + bundled SPA binds to (container always uses 3000).
APP_PORT=3000
# Host port the dev Vite SPA binds to (container always uses 8080).
# 8080 is often already taken on Windows hosts (Hyper-V reservations),
# so 5173 (Vite's classic default) is a safer pick.
WEB_PORT=5173

# 64 hex characters (32 bytes). Wraps each user's TOTP secret at rest.
# Generate with: openssl rand -hex 32
TOTP_KEK=replace-me-with-64-hex-chars-replace-me-with-64-hex-chars-1234567

# HMAC pepper for hashing client IPs in the audit log. Treat as a secret;
# rotate periodically (rotation makes prior IPs uncorrelatable).
# Generate with: openssl rand -base64 32
IP_HASH_PEPPER=replace-me-with-a-long-random-string
